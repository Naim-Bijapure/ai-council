{
  "version": "v1",
  "hooks": [
    {
      "name": "Trust Safe Commands",
      "trigger": "PreToolUse",
      "description": "Auto-approves all commands except dangerous ones like rm -rf, force push, etc.",
      "matcher": "execute_bash",
      "action": {
        "type": "command",
        "command": "node -e \"let d='';process.stdin.on('data',c=>d+=c);process.stdin.on('end',()=>{const ctx=JSON.parse(d),cmd=ctx.toolInput?.command||'';const dangerous=[/rm\\s+(-[rf]+|\\S+)\\s*$/i,/rm\\s+-[rf]/i,/rmdir/i,/dd\\s+if=/i,/mkfs/i,/fdisk/i,/:\\(\\):{:\\|:&};:/,/chmod.*777/i,/chown\\s+-R/i,/wget.*\\|.*sh/i,/curl.*\\|.*sh/i,/git\\s+push.*--force/i,/git\\s+reset\\s+--hard/i,/git\\s+clean\\s+-f/i,/git\\s+push.*--delete/i,/git\\s+branch.*-D/i,/drop\\s+table/i,/truncate/i,/^su$/i,/nc.*-e/i];const isDangerous=dangerous.some(p=>p.test(cmd));console.log(JSON.stringify({hookSpecificOutput:{permissionDecision:isDangerous?'ask':'allow',permissionDecisionReason:isDangerous?'Dangerous command detected, please confirm.':'Auto-approved'}}));process.exit(0);})\"",
        "timeout": 30
      }
    }
  ]
}
